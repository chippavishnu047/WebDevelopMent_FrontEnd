{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {},
    "variables": {
        "name": "vmuser2"
    },
    "resources": [
        {
            "name": "[toLower(concat(variables('name'), 'storage'))]",
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2015-06-15",
            "location": "[resourceGroup().location]",
            "tags": {
                "displayName": "[concat(variables('name'), ' Storage Account')]"
            },
            "properties": {
                "accountType": "Standard_LRS"
            }
        },
        {
            "name": "[concat(variables('name'), '-PublicIP')]",
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2018-08-01",
            "location": "[resourceGroup().location]",
            "tags": {
                "displayName": "[concat(variables('name'), ' Public IP Address')]"
            },
            "properties": {
                "publicIPAllocationMethod": "Dynamic",
                "dnsSettings": {
                    "domainNameLabel": "[toLower(concat(variables('name'), '-dns'))]"
                }
            }
        },
        {
            "name": "[concat(variables('name'), '-VirtualNetwork')]",
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2018-08-01",
            "location": "[resourceGroup().location]",
            "tags": {
                "displayName": "[concat(variables('name'), ' Virtual Network')]"
            },
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "10.0.0.0/16"
                    ]
                },
                "subnets": [
                    {
                        "name": "[concat(variables('name'), '-VirtualNetwork-Subnet')]",
                        "properties": {
                            "addressPrefix": "10.0.0.0/24"
                        }
                    }
                ]
            }
        },
        {
            "name": "[concat(variables('name'), '-NetworkInterface')]",
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2018-08-01",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('name'), '-PublicIP'))]",
                "[resourceId('Microsoft.Network/virtualNetworks', concat(variables('name'), '-VirtualNetwork'))]"
            ],
            "tags": {
                "displayName": "[concat(variables('name'), '-NetworkInterface')]"
            },
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipConfig1",
                        "properties": {
                            "privateIPAllocationMethod": "Dynamic",
                            "publicIPAddress": {
                                "id": "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('name'), '-PublicIP'))]"
                            },
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', concat(variables('name'), '-VirtualNetwork'), concat(variables('name'), '-VirtualNetwork-Subnet')]"
                            }
                        }
                    }
                ]
            }
        },
        {
            "name": "[variables('name')]",
            "type": "Microsoft.Compute/virtualMachines",
            "apiVersion": "2017-03-30",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', toLower(concat(variables('name'), 'storage')))]",
                "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('name'), '-NetworkInterface'))]"
            ],
            "tags": {
                "displayName": "[variables('name')]"
            },
            "properties": {
                "hardwareProfile": {
                    "vmSize": "Standard_D1"
                },
                "osProfile": {
                    "computerName": "[variables('name')]",
                    "adminUsername": "azureuser",
                    "adminPassword": "azureuser@123"
                },
                "storageProfile": {
                    "imageReference": {
                        "publisher": "Canonical",
                        "offer": "UbuntuServer",
                        "sku": "16.04-LTS",
                        "version": "latest"
                    },
                    "osDisk": {
                        "name": "[concat(variables('name'), '-OSDisk')]",
                        "caching": "ReadWrite",
                        "createOption": "FromImage"
                    }
                },
                "networkProfile": {
                    "networkInterfaces": [
                        {
                            "id": "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('name'), '-NetworkInterface'))]"
                        }
                    ]
                }
            }
        }
    ],
    "outputs": {}
}